package components.pitcher;

import components.standard.Standard;

/**
 * Pitcher kernel component with primary methods.
 *
 * @author Samuel Gassman
 *
 */
public interface PitcherKernel extends Standard<Pitcher1L> {

    /**
     * Initial stamina for any pitcher, maximum value.
     */
    int START_STAMINA = 100;

    /**
     * Stamina threshold for when a pitcher is considered tired.
     */
    int TIRED_THRESHOLD = 20;

    /**
     * Loads pitcher's season stats from data using given player ID and season year,
     * and replaces any previously stored statistics for pitcher.
     *
     * @param id
     * @param y
     *
     * @replaces this.stats
     */
    void setStats(int id, int y);

    /**
     * Returns the current stamina level of pitcher.
     */
    int stamina();

    /**
     * Adjusts stamina of pitcher by integer change. Positive value increases and negative
     * value decreases. Cannot go below 0 or above START_STAMINA.
     *
     * @param change
     */
    void adjustStamina(int change);

    /**
     * Returns total number of pitches thrown by pitcher during current outing.
     */
    int getPitchCount();

    /**
     * Records the outcome of a single pitch and updates this pitcher's in-game state accordingly.
     *
     * @param strike
     * @param foul
     * @param hitByPitch
     * @param outsRecorded
     * @param basesAdvanced
     * @param error
     * @param earnedRuns
     */
    void pitchThrown(boolean strike, boolean foul, boolean hitByPitch, int outsRecorded,
        int basesAdvanced, boolean error, int earnedRuns);

    /**
     * Returns the value of the statistic with the given key fo rthis pitcher, or 0.0
     * if the statistic is not present.
     *
     * @param key
     */
    double getStat(String key);

    /**
     * Reports whether pitcher has a recorded value for the statistic with the given key.
     *
     * @param key
     */
    boolean hasStat(String key);

    /**
     * Returns the full name of the pitcher.
     */
    String name();
}
