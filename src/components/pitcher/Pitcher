package components.pitcher;

/**
 * Enhanced interface for Pitcher component. Provides secondary methods on
 * top of PitcherKernel and Standard.
 *
 * @author Samuel Gassman
 */
public interface Pitcher extends PitcherKernel {

    /**
     * Determines recommended pitch type for this pitcher to throw based on statistical profile.
     */
    String decidePitchType();

    /**
     * Calculates the recommended location for the next pitch as a coordinate pair
     * within the strike zone plane. The plane ranges from [-1.0, 1.0] on the x axis
     * and [-1.0, 1.0] on the y-axis. values outside this range are outside the strike zone.
     */
    double[] pitchSpot();

    /**
     * Returns the effective velocity of the next pitch accounting for stamina.
     * As stamina decreases, effective velocity decreases proportionally
     * from the pitcher's recorded average fastball velocity.
     */
    double velocityDropoff();

    /**
     * Calculates this pitcher's current WHIP using kernel stat values
     * for walks, hits, and innings pitched accumulated during the current session.
     */
    double calculateWHIP();

    /**
     * Reports whether this pitcher is considered tired, defined as stamina at
     * or below TIRED_THRESHOLD.
     */
    boolean isTired();

    /**
     * Adjusts pitcher's performance stats to reflect the psychological
     * and physical pressure of a high-anxiety situation.
     */
    void tenseSituation(double leverageIndex);

    /**
     * Returns the estimated maximum velocity pitcher can sustain for the
     * remainder of the outing, based on stamina and recorded average
     * fastball velocity.
     */
    double peakRemainingVelocity();

    /**
     * Resets pitcher's in-game state without altering the stored season statistics
     * or identity fields.
     */
    void resetOutingState();

    /**
     * Returns a formatted summary of pitcher's key season statistics and
     * current in-game state, suitable for display to user.
     */
    String printSummary();

}
